// Local secrets ‚Äî not committed.
//
// 1) Copy this file next to it as `Secrets.xcconfig` (that file is listed in `.gitignore`):
//    cp Configuration/Secrets.example.xcconfig Configuration/Secrets.xcconfig
// 2) Replace the placeholder with your Melange personal key from the dashboard.
// 3) The MemoryMate target uses this file as its Xcode configuration file. Values are merged via
//    Configuration/MemoryMateSecretsMerge.plist (INFOPLIST_FILE) into the app Info.plist.

MELANGE_PERSONAL_KEY = YOUR_MELANGE_PERSONAL_KEY_HERE

// Optional overrides (merged into MemoryMate/Info.plist)
MELANGE_STRUCTURED_LLM_MODEL_NAME = changgeun/gemma-4-E2B-it
MELANGE_STRUCTURED_LLM_MODEL_VERSION = 1
// RUN_SPEED | RUN_AUTO | RUN_ACCURACY (matches LLMModelMode)
MELANGE_STRUCTURED_LLM_MODEL_MODE = RUN_AUTO
